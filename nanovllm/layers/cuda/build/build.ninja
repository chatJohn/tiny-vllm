ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=project_cuda_ops -DTORCH_API_INCLUDE_EXTENSION_H -isystem /data1/home/shxgou/code/.venv/lib/python3.12/site-packages/torch/include -isystem /data1/home/shxgou/code/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /data1/home/shxgou/.local/share/uv/python/cpython-3.12.13-linux-x86_64-gnu/include/python3.12 -fPIC -std=c++17 -std=c++17 -DGCC_VERSION=1231
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=project_cuda_ops -DTORCH_API_INCLUDE_EXTENSION_H -isystem /data1/home/shxgou/code/.venv/lib/python3.12/site-packages/torch/include -isystem /data1/home/shxgou/code/.venv/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /data1/home/shxgou/.local/share/uv/python/cpython-3.12.13-linux-x86_64-gnu/include/python3.12 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options '-fPIC' -O3 -arch=sm_80 -U__CUDA_NO_HALF_OPERATORS__ -U__CUDA_NO_HALF_CONVERSIONS__ -U__CUDA_NO_HALF2_OPERATORS__ -U__CUDA_NO_BFLOAT16_CONVERSIONS__ --expt-relaxed-constexpr --expt-extended-lambda --use_fast_math -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/data1/home/shxgou/code/.venv/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build linear.cuda.o: cuda_compile /data1/home/shxgou/code/tiny-vllm/nanovllm/layers/cuda/linear.cu
build activation.cuda.o: cuda_compile /data1/home/shxgou/code/tiny-vllm/nanovllm/layers/cuda/activation.cu
build layernorm.cuda.o: cuda_compile /data1/home/shxgou/code/tiny-vllm/nanovllm/layers/cuda/layernorm.cu
build rotary_embedding.cuda.o: cuda_compile /data1/home/shxgou/code/tiny-vllm/nanovllm/layers/cuda/rotary_embedding.cu
build embedding.cuda.o: cuda_compile /data1/home/shxgou/code/tiny-vllm/nanovllm/layers/cuda/embedding.cu
build binding.cuda.o: cuda_compile /data1/home/shxgou/code/tiny-vllm/nanovllm/layers/cuda/binding.cu





build project_cuda_ops.so: link linear.cuda.o activation.cuda.o layernorm.cuda.o rotary_embedding.cuda.o embedding.cuda.o binding.cuda.o

default project_cuda_ops.so
